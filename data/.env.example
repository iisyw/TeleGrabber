# Telegram机器人令牌 (从BotFather获取)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 图片保存目录 (默认为"downloads")
SAVE_DIR=downloads

# 代理设置 (可选，如果您的网络无法直接连接Telegram API，请取消注释并设置)
# PROXY_URL=socks5h://127.0.0.1:1080
# 或者使用HTTP代理
# PROXY_URL=http://127.0.0.1:1087

# 连接超时设置 (以秒为单位，默认30秒)
CONNECTION_TIMEOUT=30 

# 下载失败重试次数 (默认3次)
DOWNLOAD_RETRIES=3

# 可选：Web 管理后台端口（默认为 5000）
WEB_PORT=5000

# Web 管理后台登录凭据 (HTTP Basic Auth)
# 强烈建议设置；若留空，则删除等写操作接口会被禁用，只读接口仍可访问。
# 注意：Basic Auth 在明文 HTTP 上传输不安全，若需公网访问请在前面套 HTTPS 反向代理。
WEB_USERNAME=admin
WEB_PASSWORD=

# 允许使用机器人的用户列表 (可选，用逗号分隔的用户名或用户ID)
# 如果为空，则允许所有用户使用
# 例如: username1,username2,123456789
# ALLOWED_USERS=your_username,another_username 

# --- Telegram API (MTProto) 配置 ---
# 从 https://my.telegram.org 获取以支持大文件下载 (>20MB)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=